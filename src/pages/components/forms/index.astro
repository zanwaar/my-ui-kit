---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
const groups = [{ title: 'Components', links: [{ href: '/components/buttons/', label: 'Buttons' },{ href: '/components/badges/', label: 'Badges' },{ href: '/components/alerts/', label: 'Alerts' },{ href: '/components/cards/', label: 'Cards' },{ href: '/components/forms/', label: 'Forms', active: true },{ href: '/components/dropdowns/', label: 'Dropdowns' }] }];
---
<DocsLayout title="Forms" description="Dokumentasi form My UI Kit" section="components"><div class="min-h-screen lg:grid lg:grid-cols-[288px_1fr]"><Sidebar groups={groups} /><main class="p-6 lg:p-10"><span class="badge badge-primary">Component</span><h1 class="mt-3 text-3xl font-semibold">Forms</h1><section class="card mt-8 max-w-2xl"><div class="card-header">Preview</div><div class="card-body space-y-4"><div><label class="form-label">Email</label><input class="form-control" type="email" placeholder="you@example.com" /><p class="form-text">Kami tidak akan membagikan email Anda.</p></div><div><label class="form-label">Nama</label><input class="form-control is-invalid" type="text" /><p class="form-error">Nama wajib diisi.</p></div><div><label class="form-label">Pesan</label><textarea class="form-control" placeholder="Tulis pesan..."></textarea></div></div></section></main></div></DocsLayout>
