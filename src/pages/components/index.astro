---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
const groups = [
  { title: 'Getting Started', links: [{ href: '/', label: 'Introduction' }] },
  { title: 'Library', links: [
    { href: '/components/', label: 'Components', active: true },
    { href: '/blocks/', label: 'Blocks' },
    { href: '/templates/', label: 'Templates' }
  ] }
];
---
<DocsLayout title="Components" description="Komponen dasar My UI Kit" section="components">
  <div class="min-h-screen lg:grid lg:grid-cols-[260px_1fr]">
    <Sidebar groups={groups} />
    <main class="p-6 lg:p-10">
      <div class="flex items-start justify-between gap-4">
        <div>
          <span class="badge badge-primary">Components</span>
          <h1 class="mt-4 text-3xl font-semibold">Komponen Dasar</h1>
          <p class="mt-3 max-w-2xl text-neutral-600 dark:text-neutral-300">Kumpulan class semantic yang jadi fondasi blocks dan templates.</p>
        </div>
      </div>
      <section class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        <a class="card block" href="/components/buttons/"><div class="card-body"><h2 class="font-semibold">Buttons</h2><p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Aksi utama, outline, ghost, dan state disabled.</p></div></a>
        <a class="card block" href="/components/badges/"><div class="card-body"><h2 class="font-semibold">Badges</h2><p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Label status compact untuk data dan notifikasi.</p></div></a>
        <a class="card block" href="/components/alerts/"><div class="card-body"><h2 class="font-semibold">Alerts</h2><p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Pesan feedback untuk success, warning, danger, primary.</p></div></a>
        <a class="card block" href="/components/cards/"><div class="card-body"><h2 class="font-semibold">Cards</h2><p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Container konten dengan header, body, dan footer.</p></div></a>
        <a class="card block" href="/components/forms/"><div class="card-body"><h2 class="font-semibold">Forms</h2><p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Input, label, helper text, checkbox, dan textarea.</p></div></a>
        <a class="card block" href="/components/dropdowns/"><div class="card-body"><h2 class="font-semibold">Dropdowns</h2><p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Menu interaktif dengan vanilla JavaScript.</p></div></a>
      </section>
    </main>
  </div>
</DocsLayout>
