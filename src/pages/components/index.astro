---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { componentSidebar } from '../../lib/componentSidebar';
const groups = componentSidebar();
const toc = [
  { href: '#overview', label: 'Overview', active: true },
  { href: '#catalog', label: 'Component List' },
  { href: '#usage', label: 'Usage Notes' }
];
const components = [
  ['Buttons', 'Aksi utama, outline, ghost, dan state disabled.', '/components/buttons/'],
  ['Badges', 'Label status compact untuk data dan notifikasi.', '/components/badges/'],
  ['Alerts', 'Pesan feedback untuk success, warning, danger, primary.', '/components/alerts/'],
  ['Cards', 'Container konten dengan header, body, dan footer.', '/components/cards/'],
  ['Forms', 'Input, label, helper text, checkbox, dan textarea.', '/components/forms/'],
  ['Dropdowns', 'Menu interaktif dengan vanilla JavaScript.', '/components/dropdowns/']
];
---
<DocsLayout title="Components" description="Komponen dasar My UI Kit" section="components">
  <div class="min-h-screen w-full lg:grid lg:grid-cols-[260px_minmax(0,1fr)] lg:gap-4 lg:px-8 xl:px-12 2xl:grid-cols-[260px_minmax(0,1fr)_260px] 2xl:gap-6">
    <Sidebar groups={groups} />

    <main class="px-8 py-16 lg:px-0">
      <section id="overview">
        <span class="badge badge-primary">Components</span>
        <h1 class="mt-4 text-3xl font-semibold">Komponen Dasar</h1>
        <p class="mt-3 max-w-3xl text-neutral-600 dark:text-neutral-300">Kumpulan class semantic yang jadi fondasi blocks dan templates. Dokumentasi ini menampilkan komponen inti yang bisa langsung dipakai di berbagai project.</p>
      </section>

      <section class="mt-8 rounded-lg border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-900" id="usage">
        <div class="grid gap-6 xl:grid-cols-12 xl:items-start">
          <div class="xl:col-span-8">
            <p class="text-xs font-semibold uppercase tracking-wide text-primary-700 dark:text-primary-300">Usage Notes</p>
            <h2 class="mt-3 text-2xl font-semibold">Gunakan class semantic, bukan utility acak</h2>
            <p class="mt-3 text-sm leading-7 text-neutral-700 dark:text-neutral-300">Semua komponen di halaman ini dirancang untuk pemakaian plug-and-play. Pakai class seperti <code class="rounded bg-white px-2 py-1 text-xs dark:bg-neutral-800">.btn</code>, <code class="rounded bg-white px-2 py-1 text-xs dark:bg-neutral-800">.card</code>, atau <code class="rounded bg-white px-2 py-1 text-xs dark:bg-neutral-800">.form-control</code> agar tampilan tetap konsisten di seluruh kit.</p>
          </div>
          <div class="grid gap-4 sm:grid-cols-3 xl:col-span-4 xl:grid-cols-1">
            <div class="rounded-md border border-neutral-200 bg-neutral-50 p-4 dark:border-neutral-800 dark:bg-neutral-800">
              <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">Available</p>
              <strong class="mt-2 block text-2xl">6</strong>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Komponen dasar siap pakai.</p>
            </div>
            <div class="rounded-md border border-neutral-200 bg-neutral-50 p-4 dark:border-neutral-800 dark:bg-neutral-800">
              <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">Style</p>
              <strong class="mt-2 block text-base">Framework-agnostic</strong>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Bisa dipakai lintas HTML, Blade, React, dan lainnya.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="mt-8" id="catalog">
        <div class="mb-4 flex items-end justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">Catalog</p>
            <h2 class="mt-2 text-2xl font-semibold">Component List</h2>
          </div>
          <p class="text-sm text-neutral-500 dark:text-neutral-400">6 items</p>
        </div>
        <div class="grid gap-4 xl:grid-cols-2">
          {components.map(([title, desc, href]) => (
            <a class="card block transition-shadow hover:shadow-sm" href={href}>
              <div class="card-body">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h3 class="font-semibold">{title}</h3>
                    <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">{desc}</p>
                  </div>
                  <span class="text-neutral-400">→</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    </main>

    <aside class="hidden border-l border-neutral-200 py-16 pl-6 dark:border-neutral-800 2xl:block">
      <div class="sticky top-24 max-h-[calc(100vh-112px)] overflow-y-auto pr-2">
        <p class="text-sm font-semibold text-neutral-800 dark:text-neutral-100">On this page</p>
        <nav class="mt-4 space-y-1 border-l border-neutral-200 pl-4 text-sm dark:border-neutral-800">
          {toc.map((item) => (
            <a class:list={[
              'block py-1 transition-colors',
              item.active ? 'font-medium text-primary-700 dark:text-primary-300' : 'text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white'
            ]} href={item.href}>{item.label}</a>
          ))}
        </nav>
      </div>
    </aside>
  </div>
</DocsLayout>
