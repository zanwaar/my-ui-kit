---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
const groups = [{ title: 'Components', links: [{ href: '/components/buttons/', label: 'Buttons' },{ href: '/components/badges/', label: 'Badges' },{ href: '/components/alerts/', label: 'Alerts' },{ href: '/components/cards/', label: 'Cards', active: true },{ href: '/components/forms/', label: 'Forms' },{ href: '/components/dropdowns/', label: 'Dropdowns' }] }];
---
<DocsLayout title="Cards" description="Dokumentasi card My UI Kit" section="components"><div class="min-h-screen lg:grid lg:grid-cols-[260px_1fr]"><Sidebar groups={groups} /><main class="p-6 lg:p-10"><span class="badge badge-primary">Component</span><h1 class="mt-3 text-3xl font-semibold">Cards</h1><section class="mt-8 grid gap-6 lg:grid-cols-2"><div class="card"><div class="card-header">Project Summary</div><div class="card-body">Ini card dengan header dan body.</div><div class="card-footer"><button class="btn btn-primary btn-sm">Open</button></div></div><div class="card"><div class="card-body"><span class="badge badge-success">Active</span><h2 class="mt-3 text-xl font-semibold">Simple Card</h2><p class="mt-2 text-neutral-600 dark:text-neutral-300">Card juga bisa hanya memakai body.</p></div></div></section></main></div></DocsLayout>
