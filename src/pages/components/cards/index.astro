---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import ComponentDocLayout from '../../../components/ComponentDocLayout.astro';
const toc = [
  { href: '#overview', label: 'Overview', active: true },
  { href: '#preview', label: 'Preview' },
  { href: '#html', label: 'HTML' }
];
---
<DocsLayout title="Cards" description="Dokumentasi card My UI Kit" section="components">
  <ComponentDocLayout active="card" title="Card" description="Card adalah container konten untuk panel, list item, pricing box, dan section dashboard." toc={toc}>
    <Fragment slot="hero-preview">
      <div class="card"><div class="card-header">Sample</div><div class="card-body">Content card</div></div>
    </Fragment>
    <section id="preview" class="mt-8 grid gap-6 lg:grid-cols-2"><div class="card"><div class="card-header">Project Summary</div><div class="card-body">Ini card dengan header dan body.</div><div class="card-footer"><button class="btn btn-primary btn-sm">Open</button></div></div><div class="card"><div class="card-body"><span class="badge badge-success">Active</span><h2 class="mt-3 text-xl font-semibold">Simple Card</h2><p class="mt-2 text-neutral-600 dark:text-neutral-300">Card juga bisa hanya memakai body.</p></div></div></section>
    <section id="html" class="card mt-6"><div class="card-header">HTML</div><div class="card-body"><pre class="overflow-auto rounded bg-neutral-900 p-4 text-sm text-neutral-100"><code>&lt;div class="card"&gt;
  &lt;div class="card-header"&gt;Title&lt;/div&gt;
  &lt;div class="card-body"&gt;Content&lt;/div&gt;
&lt;/div&gt;</code></pre></div></section>
  </ComponentDocLayout>
</DocsLayout>
