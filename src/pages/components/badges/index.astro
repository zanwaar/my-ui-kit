---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
const groups = [
  { title: 'Components', links: [
    { href: '/components/buttons/', label: 'Buttons' },
    { href: '/components/badges/', label: 'Badges', active: true },
    { href: '/components/alerts/', label: 'Alerts' },
    { href: '/components/cards/', label: 'Cards' },
    { href: '/components/forms/', label: 'Forms' },
    { href: '/components/dropdowns/', label: 'Dropdowns' }
  ] }
];
---
<DocsLayout title="Badges" description="Dokumentasi badge My UI Kit" section="components"><div class="min-h-screen lg:grid lg:grid-cols-[288px_1fr]"><Sidebar groups={groups} /><main class="p-6 lg:p-10"><span class="badge badge-primary">Component</span><h1 class="mt-3 text-3xl font-semibold">Badges</h1><section class="card mt-8"><div class="card-header">Preview</div><div class="card-body flex flex-wrap gap-2"><span class="badge badge-primary">Primary</span><span class="badge badge-success">Success</span><span class="badge badge-danger">Danger</span><span class="badge badge-warning">Warning</span></div></section></main></div></DocsLayout>
