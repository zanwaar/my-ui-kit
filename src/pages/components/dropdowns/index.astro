---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import ComponentDocLayout from '../../../components/ComponentDocLayout.astro';
import DocsExample from '../../../components/docs/DocsExample.astro';

const toc = [
  { href: '#overview', label: 'Overview', active: true, level: 1 },
  { href: '#click-dropdown', label: 'Click dropdown', level: 2 },
  { href: '#hover-dropdown', label: 'Hover dropdown', level: 2 },
  { href: '#placement', label: 'Placement', level: 1 },
  { href: '#top-end', label: 'Top end', level: 2 },
  { href: '#right-start', label: 'Right start', level: 2 },
  { href: '#phase-2-preview', label: 'Phase 2 preview', level: 1 },
  { href: '#nested-dropdown', label: 'Nested dropdown', level: 2 },
  { href: '#menu-options', label: 'Menu options', level: 2 },
  { href: '#context-menu', label: 'Context menu', level: 2 }
];

const clickCode = `<div class="dropdown">
  <button class="dropdown-toggle btn btn-outline" data-dropdown-toggle>Open menu</button>
  <div class="dropdown-menu hidden" data-dropdown-menu>
    <a class="dropdown-item" href="#">Profile</a>
    <a class="dropdown-item" href="#">Billing</a>
    <button class="dropdown-item dropdown-close" type="button">Sign out</button>
  </div>
</div>`;

const hoverCode = `<div class="dropdown" style="--trigger: hover;">
  <button class="dropdown-toggle btn btn-outline">Hover me</button>
  <div class="dropdown-menu hidden">
    <a class="dropdown-item" href="#">Overview</a>
    <a class="dropdown-item" href="#">Analytics</a>
  </div>
</div>`;

const topEndCode = `<div class="dropdown" data-dropdown-placement="top-end">
  <button class="dropdown-toggle btn btn-outline">Top end</button>
  <div class="dropdown-menu hidden">
    <a class="dropdown-item" href="#">Duplicate</a>
    <a class="dropdown-item" href="#">Archive</a>
  </div>
</div>`;

const rightStartCode = `<div class="dropdown" data-dropdown-placement="right-start">
  <button class="dropdown-toggle btn btn-outline">Right start</button>
  <div class="dropdown-menu hidden">
    <a class="dropdown-item" href="#">Invite member</a>
    <a class="dropdown-item" href="#">Create channel</a>
  </div>
</div>`;

const nestedCode = `<div class="dropdown">
  <button class="dropdown-toggle btn btn-outline">Actions</button>
  <div class="dropdown-menu hidden">
    <a class="dropdown-item" href="#">Edit</a>
    <div class="dropdown dropdown-right">
      <button class="dropdown-item dropdown-toggle" type="button">More</button>
      <div class="dropdown-menu hidden">
        <a class="dropdown-item" href="#">Rename</a>
        <a class="dropdown-item" href="#">Move</a>
      </div>
    </div>
  </div>
</div>`;

const checkboxCode = `<div class="dropdown">
  <button class="dropdown-toggle btn btn-outline">Columns</button>
  <div class="dropdown-menu hidden" role="menu">
    <button class="dropdown-item" type="button" role="menuitemcheckbox" aria-checked="true">Name</button>
    <button class="dropdown-item" type="button" role="menuitemcheckbox" aria-checked="false">Email</button>
    <button class="dropdown-item" type="button" role="menuitemcheckbox" aria-checked="true">Role</button>
  </div>
</div>`;

const radioCode = `<div class="dropdown">
  <button class="dropdown-toggle btn btn-outline">Sort by</button>
  <div class="dropdown-menu hidden" role="menu">
    <button class="dropdown-item" type="button" role="menuitemradio" data-dropdown-radio-name="sort" aria-checked="true">Newest</button>
    <button class="dropdown-item" type="button" role="menuitemradio" data-dropdown-radio-name="sort" aria-checked="false">Oldest</button>
    <button class="dropdown-item" type="button" role="menuitemradio" data-dropdown-radio-name="sort" aria-checked="false">Name</button>
  </div>
</div>`;

const contextCode = `<div class="dropdown" style="--trigger: contextmenu;">
  <button class="dropdown-toggle btn btn-outline">Right click me</button>
  <div class="dropdown-menu hidden">
    <a class="dropdown-item" href="#">Copy link</a>
    <a class="dropdown-item" href="#">Open in new tab</a>
  </div>
</div>`;
---
<DocsLayout title="Dropdowns" description="Dokumentasi dropdown piceUI" section="components">
  <ComponentDocLayout
    active="dropdown"
    title="Dropdown"
    description="Dropdown piceUI memakai runtime internal ringan untuk click atau hover trigger, placement berbasis CSS, outside click, Escape, dan `.dropdown-close`."
    toc={toc}
  >
    <section id="overview" class="mt-8 text-base leading-7 text-neutral-600 dark:text-neutral-300">
      Gunakan struktur <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">.dropdown</code>, <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">.dropdown-toggle</code>, dan <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">.dropdown-menu</code> untuk membuat action menu yang sederhana dan aman.
      <p class="mt-4">Runtime internal mendukung click trigger, hover trigger lewat <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">--trigger: hover</code>, close saat klik di luar, close saat <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">Escape</code>, sinkronisasi <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">aria-expanded</code>, keyboard navigation dasar (<code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">Enter</code>, <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">Space</code>, <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">ArrowUp</code>, <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">ArrowDown</code>, <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">Home</code>, <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">End</code>), roving <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">tabindex</code>, typeahead huruf pertama, dan helper placement berbasis CSS.</p>
      <p class="mt-4">Fitur seperti nested dropdown kompleks masih dianggap preview phase 2 dan belum dijamin stabil di runtime internal saat ini.</p>
    </section>

    <section id="click-dropdown" class="mt-12">
      <h2 class="text-4xl font-semibold tracking-tight">Click dropdown</h2>
      <p class="mt-4 max-w-4xl text-lg leading-8 text-neutral-600 dark:text-neutral-300">Ini adalah pola utama yang direkomendasikan untuk runtime dropdown internal phase 1.</p>
      <DocsExample code={clickCode}>
        <div class="dropdown">
          <button class="dropdown-toggle btn btn-outline" data-dropdown-toggle>Open menu</button>
          <div class="dropdown-menu hidden" data-dropdown-menu>
            <a class="dropdown-item" href="#">Profile</a>
            <a class="dropdown-item" href="#">Billing</a>
            <button class="dropdown-item dropdown-close" type="button">Sign out</button>
          </div>
        </div>
      </DocsExample>
    </section>

    <section id="hover-dropdown" class="mt-12">
      <h2 class="text-4xl font-semibold tracking-tight">Hover dropdown</h2>
      <p class="mt-4 max-w-4xl text-lg leading-8 text-neutral-600 dark:text-neutral-300">Gunakan <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">--trigger: hover</code> saat menu perlu terbuka ketika pointer masuk ke area dropdown.</p>
      <DocsExample code={hoverCode}>
        <div class="dropdown" style="--trigger: hover;">
          <button class="dropdown-toggle btn btn-outline">Hover me</button>
          <div class="dropdown-menu hidden">
            <a class="dropdown-item" href="#">Overview</a>
            <a class="dropdown-item" href="#">Analytics</a>
          </div>
        </div>
      </DocsExample>
    </section>

    <section id="placement" class="mt-12">
      <h2 class="text-4xl font-semibold tracking-tight">Placement</h2>
      <p class="mt-4 max-w-4xl text-lg leading-8 text-neutral-600 dark:text-neutral-300">Phase 1 memakai helper placement berbasis CSS. Tidak ada auto flip atau collision handling JavaScript.</p>
    </section>

    <section id="top-end" class="mt-8">
      <h3 class="text-2xl font-semibold">Top end</h3>
      <DocsExample code={topEndCode}>
        <div class="dropdown" data-dropdown-placement="top-end">
          <button class="dropdown-toggle btn btn-outline">Top end</button>
          <div class="dropdown-menu hidden">
            <a class="dropdown-item" href="#">Duplicate</a>
            <a class="dropdown-item" href="#">Archive</a>
          </div>
        </div>
      </DocsExample>
    </section>

    <section id="right-start" class="mt-8">
      <h3 class="text-2xl font-semibold">Right start</h3>
      <DocsExample code={rightStartCode}>
        <div class="dropdown" data-dropdown-placement="right-start">
          <button class="dropdown-toggle btn btn-outline">Right start</button>
          <div class="dropdown-menu hidden">
            <a class="dropdown-item" href="#">Invite member</a>
            <a class="dropdown-item" href="#">Create channel</a>
          </div>
        </div>
      </DocsExample>
    </section>

    <section id="phase-2-preview" class="mt-12">
      <h2 class="text-4xl font-semibold tracking-tight">Phase 2 preview</h2>
      <p class="mt-4 max-w-4xl text-lg leading-8 text-neutral-600 dark:text-neutral-300">Contoh di bawah ini dipertahankan sebagai referensi desain dan arah API, tetapi belum dianggap fitur stabil pada runtime internal phase 1.</p>
    </section>

    <section id="nested-dropdown" class="mt-12">
      <h2 class="text-3xl font-semibold">Nested dropdown</h2>
      <p class="mt-3 text-neutral-600 dark:text-neutral-300">Preview untuk nested dropdown. Struktur ini belum dijamin stabil untuk semua kasus pada phase 1.</p>
      <DocsExample code={nestedCode}>
        <div class="dropdown">
          <button class="dropdown-toggle btn btn-outline">Actions</button>
          <div class="dropdown-menu hidden">
            <a class="dropdown-item" href="#">Edit</a>
            <div class="dropdown dropdown-right">
              <button class="dropdown-item dropdown-toggle" type="button">More</button>
              <div class="dropdown-menu hidden">
                <a class="dropdown-item" href="#">Rename</a>
                <a class="dropdown-item" href="#">Move</a>
              </div>
            </div>
          </div>
        </div>
      </DocsExample>
    </section>

    <section id="menu-options" class="mt-12">
      <h2 class="text-4xl font-semibold tracking-tight">Menu options</h2>
      <p class="mt-4 max-w-4xl text-lg leading-8 text-neutral-600 dark:text-neutral-300">Role-based item sederhana sekarang didukung untuk kebutuhan filter dan sort menu berbasis <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">aria-checked</code>.</p>
    </section>

    <section id="checkbox-items" class="mt-8">
      <h3 class="text-2xl font-semibold">Checkbox items</h3>
      <DocsExample code={checkboxCode}>
        <div class="dropdown">
          <button class="dropdown-toggle btn btn-outline">Columns</button>
          <div class="dropdown-menu hidden" role="menu">
            <button class="dropdown-item" type="button" role="menuitemcheckbox" aria-checked="true">Name</button>
            <button class="dropdown-item" type="button" role="menuitemcheckbox" aria-checked="false">Email</button>
            <button class="dropdown-item" type="button" role="menuitemcheckbox" aria-checked="true">Role</button>
          </div>
        </div>
      </DocsExample>
    </section>

    <section id="radio-items" class="mt-8">
      <h3 class="text-2xl font-semibold">Radio items</h3>
      <DocsExample code={radioCode}>
        <div class="dropdown">
          <button class="dropdown-toggle btn btn-outline">Sort by</button>
          <div class="dropdown-menu hidden" role="menu">
            <button class="dropdown-item" type="button" role="menuitemradio" data-dropdown-radio-name="sort" aria-checked="true">Newest</button>
            <button class="dropdown-item" type="button" role="menuitemradio" data-dropdown-radio-name="sort" aria-checked="false">Oldest</button>
            <button class="dropdown-item" type="button" role="menuitemradio" data-dropdown-radio-name="sort" aria-checked="false">Name</button>
          </div>
        </div>
      </DocsExample>
    </section>

    <section id="context-menu" class="mt-12">
      <h2 class="text-3xl font-semibold">Context menu</h2>
      <p class="mt-3 text-neutral-600 dark:text-neutral-300">Mode <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">contextmenu</code> sekarang membuka dropdown lewat klik kanan. Long-press touch belum ditambahkan.</p>
      <DocsExample code={contextCode}>
        <div class="dropdown" style="--trigger: contextmenu;">
          <button class="dropdown-toggle btn btn-outline">Right click me</button>
          <div class="dropdown-menu hidden">
            <a class="dropdown-item" href="#">Copy link</a>
            <a class="dropdown-item" href="#">Open in new tab</a>
          </div>
        </div>
      </DocsExample>
    </section>
  </ComponentDocLayout>
</DocsLayout>
