        <table class="table">
          <thead>
            <tr>
              <th>Parameter</th>
              <th>Description</th>
              <th>Options</th>
              <th>Default</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">--placement</code></td>
              <td>Posisi dropdown relatif terhadap trigger</td>
              <td>auto | top | top-start | top-end | bottom | bottom-start | bottom-end | left | left-start | left-end | right | right-start | right-end</td>
              <td>bottom-start</td>
            </tr>
            <tr>
              <td><code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">--offset</code></td>
              <td>Jarak antara dropdown dan trigger</td>
              <td>number (px)</td>
              <td>6</td>
            </tr>
            <tr>
              <td><code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">--scope</code></td>
              <td>Container untuk menentukan batas dropdown</td>
              <td>parent | window</td>
              <td>parent</td>
            </tr>
            <tr>
              <td><code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">--strategy</code></td>
              <td>Metode positioning dropdown</td>
              <td>absolute | fixed</td>
              <td>fixed</td>
            </tr>
            <tr>
              <td><code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">--trigger</code></td>
              <td>Event trigger untuk membuka dropdown</td>
              <td>click | hover | contextmenu</td>
              <td>click</td>
            </tr>
            <tr>
              <td><code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">--auto-close</code></td>
              <td>Kapan dropdown auto-close</td>
              <td>true | false | inside | outside</td>
              <td>true</td>
            </tr>
            <tr>
              <td><code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">--has-autofocus</code></td>
              <td>Aktifkan autofocus item/menu saat dibuka dari keyboard</td>
              <td>true | false</td>
              <td>true</td>
            </tr>
            <tr>
              <td><code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">--autofocus-on-keyboard-only</code></td>
              <td>Autofocus hanya saat dropdown dibuka lewat keyboard</td>
              <td>true | false</td>
              <td>true</td>
            </tr>
            <tr>
              <td><code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">--flip</code></td>
              <td>Aktifkan auto-flip positioning</td>
              <td>true | false</td>
              <td>true</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

