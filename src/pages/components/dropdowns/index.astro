---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
const groups = [{ title: 'Components', links: [{ href: '/components/buttons/', label: 'Buttons' },{ href: '/components/badges/', label: 'Badges' },{ href: '/components/alerts/', label: 'Alerts' },{ href: '/components/cards/', label: 'Cards' },{ href: '/components/forms/', label: 'Forms' },{ href: '/components/dropdowns/', label: 'Dropdowns', active: true }] }];
---
<DocsLayout title="Dropdowns" description="Dokumentasi dropdown My UI Kit" section="components"><div class="min-h-screen lg:grid lg:grid-cols-[288px_1fr]"><Sidebar groups={groups} /><main class="p-6 lg:p-10"><span class="badge badge-primary">Component</span><h1 class="mt-3 text-3xl font-semibold">Dropdowns</h1><section class="card mt-8"><div class="card-header">Preview</div><div class="card-body"><div class="dropdown relative inline-block"><button class="btn btn-outline" data-dropdown-toggle>Menu ▾</button><div data-dropdown-menu class="card absolute mt-2 hidden w-48 p-2"><a class="block rounded px-3 py-2 text-sm hover:bg-neutral-100 dark:hover:bg-neutral-700" href="#">Profile</a><a class="block rounded px-3 py-2 text-sm hover:bg-neutral-100 dark:hover:bg-neutral-700" href="#">Settings</a></div></div></div></section></main></div></DocsLayout>
