---
<DocsLayout title="Dropdowns" description="Dokumentasi dropdown piceUI" section="components">
  <ComponentDocLayout
    active="dropdown"
    title="Dropdown"
    description="Dropdown piceUI memakai runtime internal ringan untuk click atau hover trigger, placement berbasis CSS, outside click, Escape, dan `.dropdown-close`."
    toc={toc}
  >
    <!-- BASIC -->
    <section id="basic" class="mt-8">
      <h2 class="text-4xl font-semibold tracking-tight">Basic example</h2>
      <p class="mt-4 max-w-4xl text-lg leading-8 text-neutral-600 dark:text-neutral-300">Basic dropdown example.</p>
    </section>

    <section id="default" class="mt-8">
      <h3 class="text-2xl font-semibold">Default</h3>
      <DocsExample code={defaultCode}>
        <div class="dropdown">
          <button type="button" class="dropdown-toggle btn btn-sm btn-primary" aria-haspopup="menu" aria-expanded="false">
            Dropdown
            <span class="icon-[lucide--chevron-down] dropdown-chevron inline-block size-4 shrink-0"></span>
          </button>
          <ul class="dropdown-menu hidden min-w-60" role="menu" aria-orientation="vertical">
            <li><a class="dropdown-item" href="#">My Profile</a></li>
            <li><a class="dropdown-item" href="#">Settings</a></li>
            <li><a class="dropdown-item" href="#">Billing</a></li>
            <li><a class="dropdown-item" href="#">FAQs</a></li>
          </ul>
        </div>
      </DocsExample>
    </section>

    <!-- MENU CONTENT -->
    <section id="menu-content" class="mt-12">
      <h2 class="text-4xl font-semibold tracking-tight">Menu content</h2>
      <p class="mt-4 max-w-4xl text-lg leading-8 text-neutral-600 dark:text-neutral-300">Berbagai cara untuk menampilkan konten di dalam dropdown menu.</p>
    </section>

    <section id="dropdown-header" class="mt-8">
      <h3 class="text-2xl font-semibold">Dropdown header</h3>
      <p class="mt-2 text-neutral-600 dark:text-neutral-300">Gunakan class <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">dropdown-header</code> untuk menampilkan informasi tambahan di bagian atas dropdown.</p>
      <DocsExample code={headerCode}>
        <div class="dropdown">
          <button type="button" class="dropdown-toggle btn btn-sm btn-primary" aria-haspopup="menu" aria-expanded="false">
            Dropdown header
            <span class="icon-[lucide--chevron-down] dropdown-chevron inline-block size-4 shrink-0"></span>
          </button>
          <ul class="dropdown-menu hidden min-w-60" role="menu" aria-orientation="vertical">
            <li class="dropdown-header gap-2">
              <div class="avatar">
                <div class="w-10 rounded-full">
                  <img src="https://cdn.flyonui.com/fy-assets/avatar/avatar-2.png" alt="User Avatar" />
                </div>
              </div>
              <div>
                <h6 class="text-sm font-semibold">John Doe</h6>
                <small class="text-sm opacity-50">jhon@doe.com</small>
              </div>
            </li>
            <li><a class="dropdown-item" href="#">My Profile</a></li>
            <li><a class="dropdown-item" href="#">Settings</a></li>
            <li><a class="dropdown-item" href="#">Billing</a></li>
            <li><a class="dropdown-item" href="#">FAQs</a></li>
          </ul>
        </div>
      </DocsExample>
    </section>

    <section id="dropdown-footer" class="mt-8">
      <h3 class="text-2xl font-semibold">Dropdown footer</h3>
      <p class="mt-2 text-neutral-600 dark:text-neutral-300">Gunakan class <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">dropdown-footer</code> untuk menampilkan informasi tambahan di bagian bawah dropdown.</p>
      <DocsExample code={footerCode}>
        <div class="dropdown">
          <button type="button" class="dropdown-toggle btn btn-sm btn-primary" aria-haspopup="menu" aria-expanded="false">
            Dropdown footer
            <span class="icon-[lucide--chevron-down] dropdown-chevron inline-block size-4 shrink-0"></span>
          </button>
          <ul class="dropdown-menu hidden min-w-60" role="menu" aria-orientation="vertical">
            <li><a class="dropdown-item" href="#">My Profile</a></li>
            <li><a class="dropdown-item" href="#">Settings</a></li>
            <li><a class="dropdown-item" href="#">Billing</a></li>
            <li><a class="dropdown-item" href="#">FAQs</a></li>
            <li class="dropdown-footer gap-2">
              <button class="btn btn-error btn-soft btn-block">Sign out</button>
            </li>
          </ul>
        </div>
      </DocsExample>
    </section>

    <section id="dropdown-title" class="mt-8">
      <h3 class="text-2xl font-semibold">Dropdown title</h3>
      <p class="mt-2 text-neutral-600 dark:text-neutral-300">Gunakan class <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">dropdown-title</code> untuk menampilkan judul pada konten dropdown.</p>
      <DocsExample code={titleCode}>
        <div class="dropdown">
          <button type="button" class="dropdown-toggle btn btn-sm btn-primary" aria-haspopup="menu" aria-expanded="false">
            Dropdown title
            <span class="icon-[lucide--chevron-down] dropdown-chevron inline-block size-4 shrink-0"></span>
          </button>
          <ul class="dropdown-menu hidden min-w-60" role="menu" aria-orientation="vertical">
            <li class="dropdown-title">Settings</li>
            <li><a class="dropdown-item" href="#">My Profile</a></li>
            <li><a class="dropdown-item" href="#">Settings</a></li>
            <li><a class="dropdown-item" href="#">Billing</a></li>
            <li><a class="dropdown-item" href="#">FAQs</a></li>
            <li class="dropdown-title">Contact</li>
            <li><a class="dropdown-item" href="#">Contact support</a></li>
          </ul>
        </div>
      </DocsExample>
    </section>

    <section id="dropdown-form" class="mt-8">
      <h3 class="text-2xl font-semibold">Dropdown form</h3>
      <p class="mt-2 text-neutral-600 dark:text-neutral-300">Menggunakan form di dalam dropdown menu. Gunakan <code class="rounded bg-neutral-100 px-2 py-1 text-sm dark:bg-neutral-800">--auto-close: inside</code> agar dropdown tidak tertutup saat mengklik form elements.</p>
      <DocsExample code={formCode}>
        <div class="dropdown" style="--auto-close: inside;">
          <button type="button" class="dropdown-toggle btn btn-sm btn-primary" aria-haspopup="menu" aria-expanded="false">
            Dropdown form
            <span class="icon-[lucide--chevron-down] dropdown-chevron inline-block size-4 shrink-0"></span>
          </button>
          <div class="dropdown-menu min-w-70 hidden" role="menu" aria-orientation="vertical">
            <form class="p-4">
              <div class="mb-4">
                <label class="label-text" for="username">Username</label>
                <input type="text" placeholder="Johndoe" class="input" id="username" />
              </div>
              <div class="mb-4">
                <label class="label-text" for="password">Password</label>
                <input type="password" placeholder="············" class="input" id="password" autocomplete="password" />
              </div>
              <button type="submit" class="btn btn-primary btn-block">Sign in</button>
            </form>
          </div>
        </div>
      </DocsExample>
    </section>

    <section id="dropdown-radio" class="mt-8">
      <h3 class="text-2xl font-semibold">Dropdown radio</h3>
      <p class="mt-2 text-neutral-600 dark:text-neutral-300">Letakkan radio di dalam dropdown-item untuk membuat item dropdown dengan radio.</p>
      <DocsExample code={radioCode}>
        <div class="dropdown" style="--auto-close: inside;">
          <button type="button" class="dropdown-toggle btn btn-sm btn-primary" aria-haspopup="menu" aria-expanded="false">
            Dropdown radio
            <span class="icon-[lucide--chevron-down] dropdown-chevron inline-block size-4 shrink-0"></span>
          </button>
          <div class="dropdown-menu hidden" role="menu" aria-orientation="vertical">
            <div class="dropdown-item gap-4">
              <input id="radio-car" name="dropdown-radio" type="radio" class="radio radio-primary" checked/>
              <label for="radio-car" class="label-text block text-sm font-semibold">Car</label>
            </div>
            <div class="dropdown-item gap-4">
              <input id="radio-bicycle" name="dropdown-radio" type="radio" class="radio radio-primary" />
              <label for="radio-bicycle" class="label-text text-sm font-semibold">Bicycle</label>
            </div>
          </div>
        </div>
      </DocsExample>
    </section>

    <section id="dropdown-checkbox" class="mt-8">
      <h3 class="text-2xl font-semibold">Dropdown checkbox</h3>
      <p class="mt-2 text-neutral-600 dark:text-neutral-300">Letakkan checkbox di dalam dropdown-item untuk membuat item dropdown dengan checkbox.</p>
      <DocsExample code={checkboxCode}>
        <div class="dropdown" style="--auto-close: inside;">
          <button type="button" class="dropdown-toggle btn btn-sm btn-primary" aria-haspopup="menu" aria-expanded="false">
            Dropdown checkbox
            <span class="icon-[lucide--chevron-down] dropdown-chevron inline-block size-4 shrink-0"></span>
          </button>
          <div class="dropdown-menu hidden min-w-60" role="menu" aria-orientation="vertical">
            <div class="dropdown-item items-start gap-4">
              <input type="checkbox" class="checkbox checkbox-primary mt-2" id="cb1" checked />
              <label class="label-text flex flex-col items-start" for="cb1">
                <span class="font-semibold">Mark as important</span>
                <span class="opacity-50">Notify me when this action happens.</span>
              </label>
            </div>
            <div class="dropdown-item items-start gap-4">
              <input type="checkbox" class="checkbox checkbox-primary mt-2" id="cb2" />
              <label class="label-text flex flex-col items-start" for="cb2">
                <span class="font-semibold">Share with team</span>
                <span class="opacity-50">Notify me when this action happens.</span>
              </label>
            </div>
          </div>
        </div>
      </DocsExample>
    </section>

    <section id="dropdown-switch" class="mt-8">
      <h3 class="text-2xl font-semibold">Dropdown switch</h3>
      <p class="mt-2 text-neutral-600 dark:text-neutral-300">Letakkan switch di dalam dropdown-item untuk membuat item dropdown dengan switch.</p>
      <DocsExample code={switchCode}>
        <div class="dropdown" style="--auto-close: inside;">
          <button type="button" class="dropdown-toggle btn btn-sm btn-primary" aria-haspopup="menu" aria-expanded="false">
            Dropdown switch
            <span class="icon-[lucide--chevron-down] dropdown-chevron inline-block size-4 shrink-0"></span>
          </button>
          <div class="dropdown-menu min-w-60 hidden" role="menu" aria-orientation="vertical">
            <div class="dropdown-item items-start gap-4">
              <input type="checkbox" class="switch switch-primary mt-2" id="sw1" checked />
              <label class="label-text flex flex-col items-start" for="sw1">
                <span class="text-sm">Notifications</span>
                <span>Receive push notifications</span>
              </label>
            </div>
            <div class="dropdown-item items-start gap-4">
              <input type="checkbox" class="switch switch-primary mt-2" id="sw2" />
              <label class="label-text flex flex-col items-start" for="sw2">
                <span class="text-sm">Location Services</span>
                <span>Allow access to your location</span>
              </label>
            </div>
            <div class="dropdown-item items-start gap-4">
              <input type="checkbox" class="switch switch-primary mt-2" id="sw3" checked />
              <label class="label-text flex flex-col items-start" for="sw3">
                <span class="text-sm">Dark Theme</span>
                <span>Enable dark theme for the app</span>
              </label>
            </div>
          </div>
        </div>
      </DocsExample>
    </section>

    <!-- NESTED -->
    <section id="nested" class="mt-12">
      <h2 class="text-4xl font-semibold tracking-tight">Nested dropdowns</h2>
      <p class="mt-4 max-w-4xl text-lg leading-8 text-neutral-600 dark:text-neutral-300">Membuat dropdown bersarang dengan menambahkan dropdown di dalam dropdown.</p>
      <DocsExample code={nestedCode}>
        <div class="dropdown">
          <button type="button" class="dropdown-toggle btn btn-sm btn-primary" aria-haspopup="menu" aria-expanded="false">
            Dropdown
            <span class="icon-[lucide--chevron-down] dropdown-chevron inline-block size-4 shrink-0"></span>
          </button>
          <ul class="dropdown-menu hidden min-w-60" role="menu" aria-orientation="vertical">
            <li><a class="dropdown-item" href="#">Send My Profile</a></li>
            <li><a class="dropdown-item" href="#">View Settings</a></li>
            <li class="dropdown relative dropdown-right">
              <button class="dropdown-toggle dropdown-item justify-between" aria-haspopup="menu" aria-expanded="false">
                More Options
                <span class="icon-[lucide--chevron-right] dropdown-chevron inline-block size-4 shrink-0"></span>
              </button>
              <ul class="dropdown-menu hidden min-w-60" role="menu" aria-orientation="vertical">
                <li><a class="dropdown-item" href="#">Download Documents</a></li>
                <li><a class="dropdown-item" href="#">Manage FAQs</a></li>
              </ul>
            </li>
            <li><a class="dropdown-item" href="#">Logout</a></li>
          </ul>
        </div>
      </DocsExample>
