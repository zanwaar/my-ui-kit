---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import ComponentDocLayout from '../../../components/ComponentDocLayout.astro';
const toc = [
  { href: '#overview', label: 'Overview', active: true },
  { href: '#preview', label: 'Preview' },
  { href: '#html', label: 'HTML' }
];
---
<DocsLayout title="Dropdowns" description="Dokumentasi dropdown My UI Kit" section="components">
  <ComponentDocLayout active="dropdown" title="Dropdown" description="Dropdown memakai data attribute dan vanilla JS agar tetap framework-agnostic." toc={toc}>
    <Fragment slot="hero-preview">
      <div class="card"><div class="card-body"><button class="btn btn-outline w-full">Menu ▾</button></div></div>
    </Fragment>
    <section id="preview" class="card mt-8"><div class="card-header">Preview</div><div class="card-body"><div class="dropdown relative inline-block"><button class="btn btn-outline" data-dropdown-toggle>Menu ▾</button><div data-dropdown-menu class="card absolute mt-2 hidden w-48 p-2"><a class="block rounded px-3 py-2 text-sm hover:bg-neutral-100 dark:hover:bg-neutral-700" href="#">Profile</a><a class="block rounded px-3 py-2 text-sm hover:bg-neutral-100 dark:hover:bg-neutral-700" href="#">Settings</a></div></div></div></section>
    <section id="html" class="card mt-6"><div class="card-header">HTML</div><div class="card-body"><pre class="overflow-auto rounded bg-neutral-900 p-4 text-sm text-neutral-100"><code>&lt;button class="btn btn-outline" data-dropdown-toggle&gt;Menu&lt;/button&gt;</code></pre></div></section>
  </ComponentDocLayout>
</DocsLayout>
