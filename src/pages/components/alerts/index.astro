---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import ComponentDocLayout from '../../../components/ComponentDocLayout.astro';
const toc = [
  { href: '#overview', label: 'Overview', active: true },
  { href: '#preview', label: 'Preview' },
  { href: '#html', label: 'HTML' }
];
---
<DocsLayout title="Alerts" description="Dokumentasi alert piceUI" section="components">
  <ComponentDocLayout active="alert" title="Alert" description="Alert memberi feedback penting seperti informasi, sukses, error, atau peringatan." toc={toc}>
    <Fragment slot="hero-preview">
      <div class="card"><div class="card-body space-y-2"><div class="alert alert-primary">Informasi umum.</div><div class="alert alert-success">Berhasil disimpan.</div></div></div>
    </Fragment>
    <section id="preview" class="card mt-8"><div class="card-header">Preview</div><div class="card-body space-y-3"><div class="alert alert-primary">Informasi umum untuk pengguna.</div><div class="alert alert-success">Data berhasil disimpan.</div><div class="alert alert-danger">Terjadi kesalahan saat memproses data.</div><div class="alert alert-warning">Periksa kembali sebelum melanjutkan.</div></div></section>
    <section id="html" class="card mt-6"><div class="card-header">HTML</div><div class="card-body"><pre class="overflow-auto rounded bg-neutral-900 p-4 text-sm text-neutral-100"><code>&lt;div class="alert alert-primary"&gt;Informasi umum.&lt;/div&gt;
&lt;div class="alert alert-success"&gt;Berhasil disimpan.&lt;/div&gt;</code></pre></div></section>
  </ComponentDocLayout>
</DocsLayout>
