---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComponentDocLayout from '../../components/ComponentDocLayout.astro';

const toc = [
  { href: '#overview', label: 'Overview', active: true },
  { href: '#topics', label: 'Topics' },
  { href: '#quick-example', label: 'Quick Example' }
];

const topics = [
  {
    href: '/foundations/breakpoints/',
    title: 'Breakpoints',
    desc: 'Viewport tiers, min/max media query, dan aturan mobile-first.'
  },
  {
    href: '/foundations/containers/',
    title: 'Containers',
    desc: 'Class `.container*` dan cara kerja max-width snap per breakpoint.'
  },
  {
    href: '/foundations/grid/',
    title: 'Grid',
    desc: 'Class `.row`, `.col-*`, `.offset-*`, `.row-cols-*`, dan gutter.'
  }
];
---
<DocsLayout title="Layout Foundations" description="Overview sistem layout piceUI yang dibagi jadi breakpoint, container, dan grid." section="foundations">
  <ComponentDocLayout active="layout-foundations" title="Layout Foundations" description="Sistem layout piceUI dibagi ke beberapa topik agar lebih gampang dipelajari dan dipakai langsung." toc={toc}>
    <Fragment slot="hero-preview">
      <div class="card">
        <div class="card-body space-y-4">
          <div class="row row-tight">
            <div class="col-12 md:col-span-4"></div>
          </div>
          <div class="grid gap-3 md:grid-cols-3">
            {topics.map((topic) => (
              <a href={topic.href} class="rounded-lg border border-neutral-200 p-4 transition hover:border-primary-300 hover:bg-primary-50/50 dark:border-neutral-700 dark:hover:border-primary-700 dark:hover:bg-primary-950/30">
                <div class="font-semibold text-neutral-900 dark:text-white">{topic.title}</div>
                <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">{topic.desc}</p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </Fragment>

    <section id="overview" class="card mt-8 max-w-4xl">
      <div class="card-header">Overview</div>
      <div class="card-body space-y-4">
        <p class="text-sm text-neutral-600 dark:text-neutral-300">Layout sekarang dipisah per topik supaya lebih rapi: breakpoint untuk aturan responsive, container untuk lebar konten, dan grid untuk susunan kolom.</p>
      </div>
    </section>

    <section id="topics" class="card mt-6 max-w-4xl">
      <div class="card-header">Sub Menu</div>
      <div class="card-body grid gap-3 md:grid-cols-3">
        {topics.map((topic) => (
          <a href={topic.href} class="rounded-lg border border-neutral-200 p-4 transition hover:border-primary-300 hover:bg-primary-50/50 dark:border-neutral-700 dark:hover:border-primary-700 dark:hover:bg-primary-950/30">
            <div class="font-semibold text-neutral-900 dark:text-white">{topic.title}</div>
            <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">{topic.desc}</p>
          </a>
        ))}
      </div>
    </section>

    <section id="quick-example" class="card mt-6 max-w-4xl">
      <div class="card-header">Quick Example</div>
      <div class="card-body">
        <pre class="overflow-auto rounded bg-neutral-900 p-4 text-sm text-neutral-100"><code>&lt;div class="container"&gt;
  &lt;div class="row g-4"&gt;
    &lt;div class="col-12 col-lg-8"&gt;Content&lt;/div&gt;
    &lt;div class="col-12 col-lg-4"&gt;Sidebar&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;</code></pre>
      </div>
    </section>
  </ComponentDocLayout>
</DocsLayout>
