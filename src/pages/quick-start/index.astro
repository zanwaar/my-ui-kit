---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { componentSidebar } from '../../lib/componentSidebar';

const groups = componentSidebar('quick-start');
const toc = [
  { href: '#overview', label: 'Overview', active: true },
  { href: '#install', label: 'Install piceUI' },
  { href: '#import-css', label: 'Import CSS' },
  { href: '#first-component', label: 'First Component' },
  { href: '#development', label: 'Development Install' },
  { href: '#frameworks', label: 'Framework Notes' }
];
---
<DocsLayout title="Quick Start" description="Install dan mulai menggunakan piceUI" section="docs">
  <div class="min-h-screen w-full items-start lg:grid lg:grid-cols-[320px_minmax(0,1fr)] lg:gap-4 lg:px-8 xl:px-12 2xl:grid-cols-[320px_minmax(0,1fr)_260px] 2xl:gap-6">
    <Sidebar groups={groups} />

    <main class="px-8 py-16 lg:px-0">
      <section id="overview">
        <span class="badge badge-primary">Getting Started</span>
        <h1 class="mt-4 text-3xl font-semibold">Quick Start</h1>
        <p class="mt-3 max-w-3xl text-neutral-600 dark:text-neutral-300">
          Install piceUI dari npm, import stylesheet utama, lalu gunakan class komponen siap pakai di project Anda.
        </p>
      </section>

      <section class="mt-8 space-y-8">
        <div id="install" class="card">
          <div class="card-header">1. Install piceUI</div>
          <div class="card-body space-y-4">
            <p class="text-sm text-neutral-600 dark:text-neutral-300">Jalankan command ini di root project yang sudah memiliki `package.json`.</p>
            <pre class="overflow-auto rounded bg-neutral-900 p-4 text-sm text-neutral-100"><code>npm install piceui</code></pre>
            <p class="text-sm text-neutral-600 dark:text-neutral-300">Jika project belum memiliki `package.json`, jalankan `npm init -y` terlebih dahulu.</p>
          </div>
        </div>

        <div id="import-css" class="card">
          <div class="card-header">2. Import CSS</div>
          <div class="card-body space-y-4">
            <p class="text-sm text-neutral-600 dark:text-neutral-300">Import stylesheet utama piceUI dari entry CSS global.</p>
            <pre class="overflow-auto rounded bg-neutral-900 p-4 text-sm text-neutral-100"><code>@import "piceui/dist/ui-kit.css";</code></pre>
            <p class="text-sm text-neutral-600 dark:text-neutral-300">Atau import dari entry JavaScript/TypeScript.</p>
            <pre class="overflow-auto rounded bg-neutral-900 p-4 text-sm text-neutral-100"><code>import "piceui/dist/ui-kit.css";</code></pre>
          </div>
        </div>

        <div id="first-component" class="card">
          <div class="card-header">3. Add Your First Component</div>
          <div class="card-body space-y-4">
            <p class="text-sm text-neutral-600 dark:text-neutral-300">Gunakan class komponen langsung di markup tanpa setup tambahan.</p>
            <pre class="overflow-auto rounded bg-neutral-900 p-4 text-sm text-neutral-100"><code>&lt;button class="btn btn-primary"&gt;Install Complete&lt;/button&gt;

&lt;div class="card mt-4"&gt;
  &lt;div class="card-header"&gt;piceUI&lt;/div&gt;
  &lt;div class="card-body"&gt;Your first card is ready.&lt;/div&gt;
&lt;/div&gt;</code></pre>
          </div>
        </div>

        <div id="development" class="card">
          <div class="card-header">Development Install</div>
          <div class="card-body space-y-4">
            <p class="text-sm text-neutral-600 dark:text-neutral-300">Gunakan local install hanya saat Anda sedang mengembangkan package piceUI dari repo lokal.</p>
            <pre class="overflow-auto rounded bg-neutral-900 p-4 text-sm text-neutral-100"><code>npm install ../my-ui-kit</code></pre>
          </div>
        </div>

        <div id="frameworks" class="card">
          <div class="card-header">Framework Notes</div>
          <div class="card-body space-y-3 text-sm text-neutral-600 dark:text-neutral-300">
            <p>piceUI class dapat dipakai di HTML, Astro, Laravel Blade, React, Vue, Svelte, dan framework lain yang mendukung CSS global.</p>
            <p>Untuk project berbasis Tailwind, pastikan stylesheet piceUI dimuat setelah style dasar project agar komponen tampil konsisten.</p>
          </div>
        </div>
      </section>
    </main>

    <aside class="hidden border-l border-neutral-200 py-16 pl-6 dark:border-neutral-800 2xl:block">
      <div class="sticky top-24 max-h-[calc(100vh-112px)] overflow-y-auto pr-2">
        <p class="text-sm font-semibold text-neutral-800 dark:text-neutral-100">Quick Start</p>
        <nav class="mt-4 space-y-1 border-l border-neutral-200 pl-4 text-sm dark:border-neutral-800">
          {toc.map((item) => (
            <a class:list={[
              'block py-1 transition-colors',
              item.active ? 'font-medium text-primary-700 dark:text-primary-300' : 'text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white'
            ]} href={item.href}>{item.label}</a>
          ))}
        </nav>
      </div>
    </aside>
  </div>
</DocsLayout>
