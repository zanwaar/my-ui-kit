---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
const groups = [{ title: 'Templates', links: [{ href: '/templates/admin/', label: 'Admin Dashboard', active: true }] }];
---
<DocsLayout title="Admin Template" description="Template admin dashboard" section="templates"><div class="min-h-screen w-full lg:grid lg:grid-cols-[288px_minmax(0,1fr)] lg:gap-8 lg:px-8 xl:px-12"><Sidebar groups={groups} /><main class="px-8 py-8 lg:px-8 lg:py-10 xl:px-12"><span class="badge badge-primary">Template</span><h1 class="mt-3 text-3xl font-semibold">Admin Dashboard</h1><section class="mt-8 grid gap-4 lg:grid-cols-[1fr_320px]"><div class="card"><div class="card-header">Recent Orders</div><div class="card-body space-y-3"><div class="flex items-center justify-between rounded border border-neutral-200 p-3 dark:border-neutral-800"><span>Invoice #1001</span><span class="badge badge-success">Paid</span></div><div class="flex items-center justify-between rounded border border-neutral-200 p-3 dark:border-neutral-800"><span>Invoice #1002</span><span class="badge badge-warning">Pending</span></div></div></div><div class="card"><div class="card-header">Quick Action</div><div class="card-body space-y-3"><button class="btn btn-primary w-full">Create Report</button><button class="btn btn-outline w-full">Export Data</button></div></div></section></main></div></DocsLayout>
