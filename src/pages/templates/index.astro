---
import DocsLayout from '../../layouts/DocsLayout.astro';

type TemplateItem = {
  title: string;
  category: string;
  price: string;
  description: string;
  href: string;
  accent: string;
};

const heroTags = ['Admin dashboards', 'Landing pages', 'SaaS templates', 'Auth flows'];
const filterPills = ['All', 'Admin', 'Marketing', 'SaaS'];
const templates: TemplateItem[] = [
  {
    title: 'Admin Dashboard',
    category: 'Admin',
    price: 'Ready',
    description: 'Sidebar-driven analytics workspace with cards, tables, and quick actions.',
    href: '/templates/admin/',
    accent: 'from-primary-200 via-primary-100 to-white dark:from-primary-900 dark:via-neutral-900 dark:to-neutral-800'
  },
  {
    title: 'Startup Landing',
    category: 'Marketing',
    price: 'Soon',
    description: 'Hero-first conversion layout for SaaS products and modern launches.',
    href: '/templates/',
    accent: 'from-violet-200 via-fuchsia-100 to-white dark:from-violet-900 dark:via-neutral-900 dark:to-neutral-800'
  },
  {
    title: 'Finance Workspace',
    category: 'SaaS',
    price: 'Soon',
    description: 'Data-heavy product shell with metrics, recent activity, and structured panels.',
    href: '/templates/',
    accent: 'from-cyan-200 via-sky-100 to-white dark:from-cyan-900 dark:via-neutral-900 dark:to-neutral-800'
  },
  {
    title: 'Creator Studio',
    category: 'Admin',
    price: 'Soon',
    description: 'Content management layout for creator tools, uploads, and editorial flows.',
    href: '/templates/',
    accent: 'from-amber-100 via-orange-50 to-white dark:from-amber-900 dark:via-neutral-900 dark:to-neutral-800'
  },
  {
    title: 'Team Workspace',
    category: 'SaaS',
    price: 'Soon',
    description: 'Collaboration-focused interface for projects, tasks, and shared updates.',
    href: '/templates/',
    accent: 'from-emerald-100 via-green-50 to-white dark:from-emerald-900 dark:via-neutral-900 dark:to-neutral-800'
  },
  {
    title: 'Portfolio System',
    category: 'Marketing',
    price: 'Soon',
    description: 'Personal brand template with case studies, services, and contact sections.',
    href: '/templates/',
    accent: 'from-rose-100 via-pink-50 to-white dark:from-rose-900 dark:via-neutral-900 dark:to-neutral-800'
  }
];
---
<DocsLayout title="Templates" description="Discover page templates built with piceUI." section="templates">
  <div class="w-full px-6 py-6 lg:px-10 xl:px-12">
    <section class="mx-auto max-w-6xl" id="overview">
      <div class="space-y-3 text-center">
        <span class="badge badge-primary">Template Catalog</span>
        <h1 class="mx-auto max-w-3xl text-3xl font-semibold leading-tight text-neutral-950 dark:text-white lg:text-[30px]">Discover ready-to-use page templates for dashboards, SaaS products, and modern websites.</h1>
        <p class="mx-auto max-w-2xl text-sm text-neutral-600 dark:text-neutral-300">Browse full-page examples built with piceUI. Each template follows the same spacing, component, and layout system for faster implementation.</p>
      </div>

      <div class="mx-auto mt-6 max-w-2xl rounded-md border border-neutral-200 bg-white p-2 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
        <div class="flex items-center gap-3 px-2 py-2 text-sm text-neutral-500 dark:text-neutral-400">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <span class="flex-1">Search templates, layouts, or use cases</span>
          <span class="rounded border border-neutral-200 px-2 py-0.5 text-xs dark:border-neutral-700">⌘ K</span>
        </div>
      </div>

      <div class="mt-4 flex flex-wrap items-center justify-center gap-3">
        {heroTags.map((tag) => (
          <span class="rounded-full border border-neutral-200 bg-white px-3 py-2 text-xs text-neutral-600 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-300">{tag}</span>
        ))}
      </div>
    </section>

    <section class="mx-auto mt-6 max-w-6xl">
      <div class="flex flex-wrap items-center justify-between gap-4 rounded-md border border-neutral-200 bg-white p-4 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
        <div class="flex flex-wrap items-center gap-3">
          {filterPills.map((pill, index) => (
            <button class:list={[
              'rounded-full px-3 py-2 text-xs font-medium transition-colors',
              index === 0 ? 'bg-primary-600 text-white' : 'border border-neutral-200 bg-white text-neutral-600 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-300'
            ]}>{pill}</button>
          ))}
        </div>
        <div class="flex flex-wrap items-center gap-3 text-xs text-neutral-500 dark:text-neutral-400">
          <span class="rounded-md border border-neutral-200 px-3 py-2 dark:border-neutral-700">Any technology</span>
          <span class="rounded-md border border-neutral-200 px-3 py-2 dark:border-neutral-700">Newest first</span>
        </div>
      </div>
    </section>

    <section class="mx-auto mt-6 max-w-6xl">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
        {templates.map((item) => (
          <a class="card block transition-shadow hover:shadow-md" href={item.href}>
            <div class:list={[
              'aspect-[4/3] border-b border-neutral-200 bg-gradient-to-br p-4 dark:border-neutral-700',
              item.accent
            ]}>
              <div class="flex h-full flex-col justify-between rounded-md border border-white/60 bg-white/70 p-4 backdrop-blur dark:border-white/10 dark:bg-neutral-900/50">
                <div class="flex items-center justify-between gap-3">
                  <span class="badge badge-primary">{item.category}</span>
                  <span class:list={[
                    'text-xs font-medium',
                    item.price === 'Ready' ? 'text-green-600 dark:text-green-400' : 'text-neutral-500 dark:text-neutral-400'
                  ]}>{item.price}</span>
                </div>
                <div class="grid grid-cols-3 gap-2 opacity-80">
                  <div class="rounded bg-white/80 p-2 shadow-sm dark:bg-neutral-800/80"></div>
                  <div class="rounded bg-white/80 p-2 shadow-sm dark:bg-neutral-800/80"></div>
                  <div class="rounded bg-white/80 p-2 shadow-sm dark:bg-neutral-800/80"></div>
                  <div class="col-span-2 rounded bg-white/80 p-3 shadow-sm dark:bg-neutral-800/80"></div>
                  <div class="rounded bg-white/80 p-3 shadow-sm dark:bg-neutral-800/80"></div>
                </div>
              </div>
            </div>
            <div class="card-body space-y-2">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h2 class="font-semibold text-neutral-900 dark:text-white">{item.title}</h2>
                  <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">{item.description}</p>
                </div>
                <span class="text-neutral-400">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="mx-auto mt-8 max-w-6xl">
      <div class="rounded-lg bg-primary-600 px-6 py-8 text-white shadow-md dark:bg-primary-700 lg:px-8">
        <div class="grid gap-6 lg:grid-cols-[1.5fr_1fr] lg:items-center">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-primary-100">Get Updates</p>
            <h2 class="mt-3 text-2xl font-semibold">Need more templates in this catalog?</h2>
            <p class="mt-3 max-w-2xl text-sm text-primary-100">Use this page as the base pattern for future template releases. Keep the browsing experience stable while expanding the library.</p>
          </div>
          <div class="flex flex-wrap items-center gap-3 lg:justify-end">
            <a class="btn bg-white text-primary-700 hover:bg-primary-50" href="/layout-system/">Review Layout System</a>
            <a class="btn border border-white/30 text-white hover:bg-white/10" href="/components/">Browse Components</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</DocsLayout>
