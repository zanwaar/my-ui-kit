---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
const groups = [
  { title: 'Getting Started', links: [{ href: '/', label: 'Introduction' }] },
  { title: 'Library', links: [
    { href: '/components/', label: 'Components' },
    { href: '/blocks/', label: 'Blocks' },
    { href: '/templates/', label: 'Templates', active: true }
  ] }
];
---
<DocsLayout title="Templates" description="Template halaman piceUI" section="templates">
  <div class="min-h-screen w-full lg:grid lg:grid-cols-[288px_minmax(0,1fr)] lg:gap-8 lg:px-8 xl:px-12">
    <Sidebar groups={groups} />
    <main class="px-8 py-8 lg:px-8 lg:py-10 xl:px-12">
      <span class="badge badge-primary">Templates</span>
      <h1 class="mt-4 text-3xl font-semibold">Template Halaman</h1>
      <p class="mt-3 max-w-2xl text-neutral-600 dark:text-neutral-300">Template adalah halaman utuh berbasis components dan blocks.</p>
      <section class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        <a class="card block" href="/templates/admin/"><div class="card-body"><span class="badge badge-success">Ready</span><h2 class="mt-3 font-semibold">Admin Dashboard</h2><p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Layout dashboard dengan sidebar dan cards.</p></div></a>
      </section>
    </main>
  </div>
</DocsLayout>
