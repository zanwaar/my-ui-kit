---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
const groups = [{ title: 'Blocks', links: [{ href: '/blocks/dashboard/', label: 'Dashboard Stats', active: true }] }];
---
<DocsLayout title="Dashboard Block" description="Block dashboard stats" section="blocks">
  <div class="min-h-screen w-full lg:grid lg:grid-cols-[288px_minmax(0,1fr)] lg:gap-8 lg:px-8 xl:px-12">
    <Sidebar groups={groups} />
    <main class="px-6 py-8 lg:px-0 lg:py-10">
      <div class="container-fluid">
        <span class="badge badge-success">Block</span>
        <h1 class="mt-3 text-3xl font-semibold">Dashboard Stats</h1>

        <section class="row g-4 mt-8">
          <div class="col-12 col-md-4">
            <div class="card h-full">
              <div class="card-body">
                <p class="text-sm text-neutral-500 dark:text-neutral-400">Revenue</p>
                <div class="mt-3 flex items-end justify-between">
                  <strong class="text-2xl">Rp 24,8jt</strong>
                  <span class="badge badge-success">+12%</span>
                </div>
              </div>
            </div>
          </div>
          <div class="col-12 col-md-4">
            <div class="card h-full">
              <div class="card-body">
                <p class="text-sm text-neutral-500 dark:text-neutral-400">Orders</p>
                <div class="mt-3 flex items-end justify-between">
                  <strong class="text-2xl">1.240</strong>
                  <span class="badge badge-primary">Aktif</span>
                </div>
              </div>
            </div>
          </div>
          <div class="col-12 col-md-4">
            <div class="card h-full">
              <div class="card-body">
                <p class="text-sm text-neutral-500 dark:text-neutral-400">Pending</p>
                <div class="mt-3 flex items-end justify-between">
                  <strong class="text-2xl">18</strong>
                  <span class="badge badge-warning">Review</span>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </main>
  </div>
</DocsLayout>
