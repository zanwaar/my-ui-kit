---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
const groups = [{ title: 'Blocks', links: [{ href: '/blocks/dashboard/', label: 'Dashboard Stats', active: true }] }];
---
<DocsLayout title="Dashboard Block" description="Block dashboard stats" section="blocks"><div class="min-h-screen lg:grid lg:grid-cols-[260px_1fr]"><Sidebar groups={groups} /><main class="p-6 lg:p-10"><span class="badge badge-success">Block</span><h1 class="mt-3 text-3xl font-semibold">Dashboard Stats</h1><section class="mt-8 grid gap-4 md:grid-cols-3"><div class="card"><div class="card-body"><p class="text-sm text-neutral-500 dark:text-neutral-400">Revenue</p><div class="mt-3 flex items-end justify-between"><strong class="text-2xl">Rp 24,8jt</strong><span class="badge badge-success">+12%</span></div></div></div><div class="card"><div class="card-body"><p class="text-sm text-neutral-500 dark:text-neutral-400">Orders</p><div class="mt-3 flex items-end justify-between"><strong class="text-2xl">1.240</strong><span class="badge badge-primary">Aktif</span></div></div></div><div class="card"><div class="card-body"><p class="text-sm text-neutral-500 dark:text-neutral-400">Pending</p><div class="mt-3 flex items-end justify-between"><strong class="text-2xl">18</strong><span class="badge badge-warning">Review</span></div></div></div></section></main></div></DocsLayout>
