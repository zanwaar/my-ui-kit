---
import DocsLayout from '../layouts/DocsLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { componentSidebar } from '../lib/componentSidebar';

const groups = componentSidebar('introduction');
const toc = [
  { href: '#overview', label: 'Overview', active: true },
  { href: '#what-is-piceui', label: 'What is piceUI' },
  { href: '#package-flow', label: 'Package Flow' },
  { href: '#next-steps', label: 'Next Steps' }
];
---
<DocsLayout title="Introduction" description="Pengenalan piceUI dan alur dokumentasi" section="docs">
  <div class="min-h-screen w-full items-start lg:grid lg:grid-cols-[320px_minmax(0,1fr)] lg:gap-4 lg:px-8 xl:px-12 2xl:grid-cols-[320px_minmax(0,1fr)_260px] 2xl:gap-6">
    <Sidebar groups={groups} />

    <main class="px-8 py-16 lg:px-0">
      <section id="overview">
        <span class="badge badge-primary">Getting Started</span>
        <h1 class="mt-4 text-3xl font-semibold">Introduction</h1>
        <p class="mt-3 max-w-3xl text-neutral-600 dark:text-neutral-300">
          piceUI adalah UI kit berbasis class siap pakai untuk membangun interface konsisten dengan komponen, blocks, dan templates yang reusable.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a class="btn btn-primary" href="/quick-start/">Mulai Quick Start</a>
          <a class="btn btn-outline" href="/components/">Lihat Components</a>
        </div>
      </section>

      <section class="mt-8 space-y-8">
        <div id="what-is-piceui" class="card">
          <div class="card-header">What is piceUI?</div>
          <div class="card-body space-y-3 text-sm text-neutral-600 dark:text-neutral-300">
            <p>piceUI menyediakan pattern visual yang stabil untuk tombol, form, card, navigation, overlay, table, block, dan template.</p>
            <p>Tujuannya adalah mempercepat development tanpa membuat variasi styling acak di setiap halaman.</p>
          </div>
        </div>

        <div id="package-flow" class="grid gap-4 lg:grid-cols-3">
          <div class="card">
            <div class="card-body">
              <span class="badge badge-primary">1</span>
              <h2 class="mt-3 font-semibold">Install</h2>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Install package lewat npm di halaman Quick Start.</p>
            </div>
          </div>
          <div class="card">
            <div class="card-body">
              <span class="badge badge-primary">2</span>
              <h2 class="mt-3 font-semibold">Import</h2>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Import stylesheet global piceUI ke project Anda.</p>
            </div>
          </div>
          <div class="card">
            <div class="card-body">
              <span class="badge badge-primary">3</span>
              <h2 class="mt-3 font-semibold">Build</h2>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Pakai class komponen untuk menyusun UI konsisten.</p>
            </div>
          </div>
        </div>

        <div id="next-steps" class="grid gap-4 lg:grid-cols-3">
          <a class="card block" href="/quick-start/">
            <div class="card-body">
              <h2 class="font-semibold">Quick Start</h2>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Ikuti instruksi install npm dan import CSS.</p>
            </div>
          </a>
          <a class="card block" href="/components/">
            <div class="card-body">
              <h2 class="font-semibold">Components</h2>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Jelajahi komponen dasar sampai advanced.</p>
            </div>
          </a>
          <a class="card block" href="/templates/">
            <div class="card-body">
              <h2 class="font-semibold">Templates</h2>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">Mulai dari layout halaman utuh siap pakai.</p>
            </div>
          </a>
        </div>
      </section>
    </main>

    <aside class="hidden border-l border-neutral-200 py-16 pl-6 dark:border-neutral-800 2xl:block">
      <div class="sticky top-24 max-h-[calc(100vh-112px)] overflow-y-auto pr-2">
        <p class="text-sm font-semibold text-neutral-800 dark:text-neutral-100">Introduction</p>
        <nav class="mt-4 space-y-1 border-l border-neutral-200 pl-4 text-sm dark:border-neutral-800">
          {toc.map((item) => (
            <a class:list={[
              'block py-1 transition-colors',
              item.active ? 'font-medium text-primary-700 dark:text-primary-300' : 'text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white'
            ]} href={item.href}>{item.label}</a>
          ))}
        </nav>
      </div>
    </aside>
  </div>
</DocsLayout>
