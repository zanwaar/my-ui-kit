---
import Sidebar from './Sidebar.astro';
import { componentSidebar } from '../lib/componentSidebar';
interface TocItem { href: string; label: string; active?: boolean }
interface Props {
  active: string;
  title: string;
  description: string;
  toc?: TocItem[];
}
const { active, title, description, toc = [] } = Astro.props;
const groups = componentSidebar(active);
---
<div class="min-h-screen w-full items-start lg:grid lg:grid-cols-[260px_minmax(0,1fr)] lg:gap-4 lg:px-8 xl:px-12 2xl:grid-cols-[260px_minmax(0,1fr)_260px] 2xl:gap-6">
  <Sidebar groups={groups} />

  <main class="px-8 py-16 lg:px-0">
    <section id="overview">
      <span class="badge badge-primary">Component</span>
      <h1 class="mt-4 text-3xl font-semibold">{title}</h1>
      <p class="mt-3 max-w-3xl text-neutral-600 dark:text-neutral-300">{description}</p>
    </section>

    <slot />
  </main>

  <aside class="hidden border-l border-neutral-200 py-16 pl-6 dark:border-neutral-800 2xl:block">
    <div class="sticky top-24 max-h-[calc(100vh-112px)] overflow-y-auto pr-2">
      <p class="text-sm font-semibold text-neutral-800 dark:text-neutral-100">{title}</p>
      <nav class="mt-4 space-y-1 border-l border-neutral-200 pl-4 text-sm dark:border-neutral-800">
        {toc.map((item) => (
          <a class:list={[
            'block py-1 transition-colors',
            item.active ? 'font-medium text-primary-700 dark:text-primary-300' : 'text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white'
          ]} href={item.href}>{item.label}</a>
        ))}
      </nav>
    </div>
  </aside>
</div>
