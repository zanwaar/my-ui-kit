---
interface LinkItem { href: string; label: string; active?: boolean }
interface Group { title: string; links: LinkItem[] }
interface Props { groups: Group[] }
const { groups } = Astro.props;
---
<aside class="border-b border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900 lg:sticky lg:top-0 lg:h-screen lg:border-b-0 lg:border-r">
  <a class="text-lg font-semibold" href="/">My UI Kit</a>
  <nav class="mt-8 space-y-6 text-sm">
    {groups.map((group) => (
      <div>
        <p class="mb-2 font-medium text-neutral-500 dark:text-neutral-400">{group.title}</p>
        {group.links.map((link) => (
          <a class:list={[
            'block rounded px-3 py-2',
            link.active ? 'bg-primary-50 text-primary-700 dark:bg-neutral-800 dark:text-primary-300' : 'hover:bg-neutral-100 dark:hover:bg-neutral-800'
          ]} href={link.href}>{link.label}</a>
        ))}
      </div>
    ))}
  </nav>
</aside>
