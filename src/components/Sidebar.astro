  layers: '<path d="m12 3 9 4.5-9 4.5L3 7.5 12 3Z"></path><path d="m3 12 9 4.5 9-4.5"></path><path d="m3 16.5 9 4.5 9-4.5"></path>',
  pointer: '<path d="M12 19V5"></path><path d="m5 12 7-7 7 7"></path>',
  tag: '<path d="M20 10 10 20 4 14 14 4h6v6Z"></path><path d="M17 7h.01"></path>',
  alert: '<path d="M12 9v4"></path><path d="M12 17h.01"></path><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"></path>',
  square: '<rect x="4" y="4" width="16" height="16" rx="2"></rect>',
