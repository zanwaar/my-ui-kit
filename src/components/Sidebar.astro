---
interface LinkItem { href: string; label: string; active?: boolean }
interface Group { title: string; links: LinkItem[] }
interface Props { groups: Group[] }
const { groups } = Astro.props;
---
<aside class="border-b border-neutral-200 bg-white px-6 py-6 dark:border-neutral-800 dark:bg-neutral-900 lg:sticky lg:top-0 lg:h-screen lg:border-b-0 lg:border-r">
  <a class="block text-lg font-semibold" href="/">My UI Kit</a>
  <nav class="mt-8 space-y-8 text-sm">
    {groups.map((group) => (
      <div>
        <p class="mb-3 px-3 text-xs font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">{group.title}</p>
        <div class="space-y-2">
        {group.links.map((link) => (
          <a class:list={[
            'block rounded-md px-4 py-2 transition-colors',
            link.active ? 'bg-primary-50 font-medium text-primary-700 shadow-sm dark:bg-neutral-800 dark:text-primary-300' : 'text-neutral-700 hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-300 dark:hover:bg-neutral-800 dark:hover:text-white'
          ]} href={link.href}>{link.label}</a>
        ))}
        </div>
      </div>
    ))}
  </nav>
</aside>
