---
interface LinkItem { href: string; label: string; icon?: string; badge?: string; active?: boolean; children?: LinkItem[] }
interface Group { title: string; links: LinkItem[] }
interface Props { groups: Group[] }
const { groups } = Astro.props;

const iconClass = 'h-4 w-4 shrink-0';
const iconMap: Record<string, string> = {
  home: 'icon-[lucide--house]',
  layout: 'icon-[lucide--panel-left]',
  layers: 'icon-[lucide--layers-3]',
  pointer: 'icon-[lucide--mouse-pointer-2]',
  tag: 'icon-[lucide--tag]',
  alert: 'icon-[lucide--triangle-alert]',
  square: 'icon-[lucide--square]',
  chevrons: 'icon-[lucide--chevrons-up-down]',
  form: 'icon-[lucide--form-input]',
  grid: 'icon-[lucide--grid-2x2]',
  window: 'icon-[lucide--app-window]',
  sliders: 'icon-[lucide--sliders-horizontal]',
  settings: 'icon-[lucide--settings]',
  paint: 'icon-[lucide--palette]',
  palette: 'icon-[lucide--swatch-book]',
  sparkle: 'icon-[lucide--sparkles]',
  moon: 'icon-[lucide--moon-star]',
  code: 'icon-[lucide--code-xml]',
  'align-right': 'icon-[lucide--align-right]',
  wand: 'icon-[lucide--wand-sparkles]'
};
---
<aside class="bg-transparent px-6 py-12 lg:sticky lg:top-16 lg:h-[calc(100vh-64px)] lg:self-start">
  <div class="lg:h-full lg:overflow-y-auto lg:pr-2">
  <nav class="space-y-8 text-sm">
    {groups.map((group) => (
      <div>
        <p class="mb-3 px-3 text-xs font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">{group.title}</p>
        <div class="space-y-2">
        {group.links.map((link) => (
          <div class="space-y-2">
            <a class:list={[
              'flex items-center gap-3 rounded-md px-4 py-2.5 transition-colors',
              link.active ? 'font-medium text-primary-700 dark:text-primary-300' : 'text-neutral-700 hover:text-neutral-900 dark:text-neutral-300 dark:hover:text-white'
            ]} href={link.href}>
              {link.icon && <span class:list={[iconMap[link.icon] || '', iconClass]} aria-hidden="true"></span>}
              <span>{link.label}</span>
              {link.badge && <span class="ml-auto rounded-full bg-orange-50 px-2 py-0.5 text-xs font-medium text-orange-600 dark:bg-orange-950 dark:text-orange-300">{link.badge}</span>}
            </a>

            {link.children && link.children.length > 0 && (
              <div class="ml-4 border-l border-neutral-200 pl-4 dark:border-neutral-800">
                <div class="space-y-1">
                  {link.children.map((child) => (
                    <div>
                      <a class:list={[
                        'flex items-center gap-3 rounded-md px-3 py-2.5 text-sm transition-colors',
                        child.active ? 'font-medium text-primary-700 dark:text-primary-300' : 'text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white'
                      ]} href={child.href}>
                        <span>{child.label}</span>
                        {child.badge && <span class="ml-auto rounded-full bg-orange-50 px-2 py-0.5 text-xs font-medium text-orange-600 dark:bg-orange-950 dark:text-orange-300">{child.badge}</span>}
                      </a>

                      {child.children && child.children.length > 0 && (
                        <div class="ml-3 border-l border-neutral-200 pl-3 dark:border-neutral-800">
                          <div class="space-y-1">
                            {child.children.map((subChild) => (
                              <a class:list={[
                                'block rounded-md px-3 py-1 text-sm transition-colors',
                                subChild.active ? 'font-medium text-primary-700 dark:text-primary-300' : 'text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white'
                              ]} href={subChild.href}>{subChild.label}</a>
                            ))}
                          </div>
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
        </div>
      </div>
    ))}
  </nav>
  </div>
</aside>
