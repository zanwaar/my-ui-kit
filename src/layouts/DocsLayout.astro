---
interface Props {
  title: string;
  description?: string;
  section?: 'docs' | 'foundations' | 'components' | 'blocks' | 'templates';
}

const { title, description = 'piceUI documentation', section = 'docs' } = Astro.props;
const navClass = (key: string) => key === section
  ? 'text-primary-600 dark:text-primary-400'
  : 'text-neutral-700 hover:text-neutral-900 dark:text-neutral-300 dark:hover:text-white';
const iconClass = 'h-4 w-4';
const themeItems = [
  { name: 'light', label: 'Light', swatches: ['#7c3aed', '#9ca3af', '#3b82f6', '#a3a3a3'] },
  { name: 'dark', label: 'Dark', swatches: ['#7c3aed', '#6b7280', '#3b82f6', '#9ca3af'] },
  { name: 'black', label: 'Black', swatches: ['#8b5cf6', '#14b8a6', '#4f46e5', '#27272a'] },
  { name: 'claude', label: 'Claude', swatches: ['#cd6e49', '#a78bfa', '#155e75', '#292524'] },
  { name: 'corporate', label: 'Corporate', swatches: ['#3b82f6', '#6b7280', '#ec4899', '#334155'] },
  { name: 'ghibli', label: 'Ghibli', swatches: ['#928b4a', '#64748b', '#14b8a6', '#f1e5c5'] },
  { name: 'gourmet', label: 'Gourmet', swatches: ['#f97316', '#78716c', '#ec4899', '#f8fafc'] },
  { name: 'luxury', label: 'Luxury', swatches: ['#d97706', '#6b7280', '#be123c', '#1c1917'] },
  { name: 'marshmallow', label: 'Marshmallow', swatches: ['#f472b6', '#a78bfa', '#5eead4', '#fff1f2'] },
  { name: 'mintlify', label: 'Mintlify', swatches: ['#10b981', '#60a5fa', '#0ea5e9', '#ecfdf5'] },
  { name: 'pastel', label: 'Pastel', swatches: ['#a855f7', '#93c5fd', '#f9a8d4', '#f5f3ff'] },
  { name: 'perplexity', label: 'Perplexity', swatches: ['#0ea5e9', '#22d3ee', '#334155', '#111827'] },
  { name: 'shadcn', label: 'Shadcn', swatches: ['#0f172a', '#94a3b8', '#e2e8f0', '#ffffff'] },
  { name: 'slack', label: 'Slack', swatches: ['#4a154b', '#2eb67d', '#36c5f0', '#e01e5a'] },
  { name: 'soft', label: 'Soft', swatches: ['#7c3aed', '#8b5cf6', '#ec4899', '#f5f3ff'] },
  { name: 'spotify', label: 'Spotify', swatches: ['#22c55e', '#1f2937', '#8b5cf6', '#0a0a0a'] },
  { name: 'valorant', label: 'Valorant', swatches: ['#ef4444', '#6366f1', '#2dd4bf', '#0f172a'] },
  { name: 'vscode', label: 'VSCode', swatches: ['#3b82f6', '#10b981', '#8b5cf6', '#181818'] }
];
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — piceUI</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="stylesheet" href="/ui-kit.css" />
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()} />
  </head>
  <body class="bg-neutral-50 text-neutral-900 dark:bg-neutral-900 dark:text-neutral-100">
    <header class="sticky top-0 z-40 border-b border-neutral-200 bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/85 dark:border-neutral-800 dark:bg-neutral-900/90 dark:supports-[backdrop-filter]:bg-neutral-900/80">
      <div class="flex w-full items-center gap-6 px-6 py-4 lg:px-10 xl:px-12">
        <a class="flex shrink-0 items-center gap-2" href="/" aria-label="piceUI home">
          <img class="h-8 w-8 object-contain" src="/brand/piceui-icon.png" alt="" aria-hidden="true" />
          <span class="text-lg font-semibold tracking-tight text-neutral-900 dark:text-white">pice<span class="text-primary-600 dark:text-primary-400">UI</span></span>
        </a>

        <div class="hidden min-w-0 flex-1 lg:block">
          <label class="flex max-w-md items-center gap-3 rounded-md border border-neutral-300 bg-white px-4 py-2 text-sm text-neutral-500 shadow-sm dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-400">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={iconClass} aria-hidden="true">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
            <span class="flex-1">Search documentation</span>
            <span class="rounded border border-neutral-200 px-2 py-0.5 text-xs dark:border-neutral-700">⌘ K</span>
          </label>
        </div>

        <nav class="ml-auto flex items-center gap-4 text-sm lg:gap-6">
          <a class={navClass('docs')} href="/">Docs</a>
          <a class={navClass('foundations')} href="/layout-system/">Foundations</a>
          <a class={navClass('components')} href="/components/">Components</a>
          <a class={navClass('blocks')} href="/blocks/">Blocks</a>
          <a class={navClass('templates')} href="/templates/">Templates</a>
          <div class="hidden items-center gap-3 border-l border-neutral-200 pl-4 dark:border-neutral-800 lg:flex">
            <a class="text-neutral-500 transition-colors hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white" href="https://github.com" target="_blank" rel="noreferrer" aria-label="GitHub">
              <svg viewBox="0 0 24 24" fill="currentColor" class={iconClass} aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.7-2.782.605-3.37-1.344-3.37-1.344-.454-1.157-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.091-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.56 9.56 0 0 1 2.504.337c1.909-1.296 2.747-1.026 2.747-1.026.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.31.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.481A10.019 10.019 0 0 0 22 12.017C22 6.484 17.523 2 12 2Z"></path></svg>
            </a>
            <a class="text-neutral-500 transition-colors hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white" href="https://t.me" target="_blank" rel="noreferrer" aria-label="Telegram">
              <svg viewBox="0 0 24 24" fill="currentColor" class={iconClass} aria-hidden="true"><path d="M21.944 4.666a1 1 0 0 0-1.153-.168L3.603 11.55a1 1 0 0 0 .082 1.865l4.37 1.59 1.59 4.37a1 1 0 0 0 1.865.082l7.052-17.188a1 1 0 0 0-.618-1.603ZM9.84 14.16l-.86 3.098-.98-2.696 8.91-6.127-7.07 5.726Z"></path></svg>
            </a>
          </div>
          <div class="dropdown shrink-0">
            <button class="dropdown-toggle btn btn-outline btn-sm h-10 min-w-28 justify-between px-4" data-dropdown-toggle aria-expanded="false">
              <span data-theme-toggle-label>Theme</span>
              <span class="text-sm leading-none">⌃</span>
            </button>
            <div data-dropdown-menu class="dropdown-menu absolute right-0 hidden w-80 overflow-y-auto rounded-2xl p-2" style="max-height: min(26rem, calc(100vh - 6rem));">
              <div class="space-y-1 pr-1">
                {themeItems.map((theme) => (
                  <button
                    class="dropdown-item h-14 justify-between gap-4 rounded-xl px-4 text-base font-medium"
                    type="button"
                    data-theme-option={theme.name}
                    aria-pressed="false"
                  >
                    <span class="min-w-0 truncate">{theme.label}</span>
                    <span class="flex shrink-0 items-center gap-1.5">
                      {theme.swatches.map((swatch) => (
                        <span class="h-7 w-2.5 rounded-sm" style={`background:${swatch}`}></span>
                      ))}
                    </span>
                  </button>
                ))}
              </div>
            </div>
          </div>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <script is:inline src="/js/theme-toggle.js"></script>
    <script is:inline src="/js/dropdown.js"></script>
    <script is:inline src="/js/sidebar.js"></script>
    <script is:inline src="/js/modal.js"></script>
    <script is:inline src="/js/docs-example.js"></script>
    <script is:inline src="/js/docs-toc.js"></script>
    <script is:inline src="/pagefind/pagefind-ui.js"></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        const search = document.querySelector('#search');
        if (search && window.PagefindUI) {
          new window.PagefindUI({ element: '#search', showSubResults: true, resetStyles: false });
        }
      });
    </script>
  </body>
</html>
