---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Admin Dashboard Template' } = Astro.props;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — piceUI</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="stylesheet" href="/ui-kit.css" />
  </head>
  <body class="h-screen overflow-hidden bg-neutral-50 text-neutral-900 dark:bg-neutral-900 dark:text-neutral-100">
    <slot />
    <script is:inline src="/js/theme-toggle.js"></script>
    <script is:inline src="/js/sidebar.js"></script>
    <script is:inline src="/js/modal.js"></script>
  </body>
</html>
